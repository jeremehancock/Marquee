{% extends 'layout.html.twig' %}

{% block title %}Import from Plex · {{ site_title }}{% endblock %}

{% block content %}
    <p><a class="search__clear" href="/library/movies">&larr; Back to library</a></p>
    <h1>Import from Plex</h1>

    {% if flash %}
        <p class="alert alert--{{ flash.type }}" role="alert">{{ flash.message }}</p>
    {% endif %}

    {% if not configured %}
        <div class="panel">
            <p>Plex is not configured yet. Set <code>PLEX_SERVER_URL</code> and
               <code>PLEX_TOKEN</code> in your environment and restart Marquee.</p>
        </div>
    {% elseif error %}
        <p class="alert" role="alert">{{ error }}</p>
    {% elseif libraries is empty %}
        <div class="panel"><p>No movie or TV libraries were found on your Plex server.</p></div>
    {% else %}
        <form class="panel form" method="post" action="/plex/import"
              x-data="{ movies: 0, shows: 0, importing: false }" @submit="importing = true">
            <fieldset class="fieldset">
                <legend>Libraries</legend>
                {% for library in libraries %}
                    <label class="check">
                        <input type="checkbox" name="sections[]" value="{{ library.key }}"
                               @change="{{ library.isMovie ? 'movies' : 'shows' }} += $event.target.checked ? 1 : -1">
                        {{ library.title }}
                        <span class="check__meta">{{ library.isMovie ? 'Movies' : 'TV' }}</span>
                    </label>
                {% endfor %}
            </fieldset>

            <fieldset class="fieldset">
                <legend>What to import</legend>
                <p class="check__hint">Options match the types of the libraries you select.</p>
                {% for type in mediaTypes %}
                    {% set cond = {'movie': 'movies > 0', 'show': 'shows > 0', 'season': 'shows > 0', 'collection': '(movies > 0 || shows > 0)'}[type.value] %}
                    <label class="check">
                        <input type="checkbox" name="types[]" value="{{ type.value }}"
                               :disabled="!({{ cond }})" x-effect="if (!({{ cond }})) $el.checked = false">
                        <span :class="!({{ cond }}) ? 'is-disabled' : ''">{{ type.label }}</span>
                    </label>
                {% endfor %}
            </fieldset>

            <button type="submit" class="btn btn--accent" :disabled="importing">Import</button>

            <div class="overlay" x-show="importing" x-cloak style="display:none">
                <div class="overlay__box">
                    <div class="spinner"></div>
                    <p><strong>Importing from Plex&hellip;</strong></p>
                    <p class="stats">This can take a while for large libraries. Please keep this page open.</p>
                </div>
            </div>
        </form>
        <p class="stats">Plex is the source of truth: importing overwrites posters that changed in Plex.</p>
    {% endif %}
{% endblock %}
