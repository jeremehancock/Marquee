{% extends 'layout.html.twig' %}

{% block title %}Import from Plex · {{ site_title }}{% endblock %}

{% block content %}
    <p><a class="search__clear" href="/library/movies">&larr; Back to library</a></p>
    <h1>Import from Plex</h1>

    {% if flash %}
        <p class="alert alert--{{ flash.type }}" role="alert">{{ flash.message }}</p>
    {% endif %}

    {% if not configured %}
        <div class="panel">
            <p>Plex is not configured yet. Set <code>PLEX_SERVER_URL</code> and
               <code>PLEX_TOKEN</code> in your environment and restart Marquee.</p>
        </div>
    {% elseif error %}
        <p class="alert" role="alert">{{ error }}</p>
    {% elseif libraries is empty %}
        <div class="panel"><p>No movie or TV libraries were found on your Plex server.</p></div>
    {% else %}
        <form class="panel form" method="post" action="/plex/import">
            <fieldset class="fieldset">
                <legend>Libraries</legend>
                {% for library in libraries %}
                    <label class="check">
                        <input type="checkbox" name="sections[]" value="{{ library.key }}">
                        {{ library.title }}
                        <span class="check__meta">{{ library.isMovie ? 'Movies' : 'TV' }}</span>
                    </label>
                {% endfor %}
            </fieldset>

            <fieldset class="fieldset">
                <legend>What to import</legend>
                {% for type in mediaTypes %}
                    <label class="check">
                        <input type="checkbox" name="types[]" value="{{ type.value }}">
                        {{ type.label }}
                    </label>
                {% endfor %}
            </fieldset>

            <button type="submit" class="btn btn--accent">Import</button>
        </form>
        <p class="stats">Plex is the source of truth: importing overwrites posters that changed in Plex.</p>
    {% endif %}
{% endblock %}
